#!/usr/bin/env sh

set -eu

APP_HOME=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
WRAPPER_SCRIPT="$APP_HOME/hvigor/hvigor-wrapper.js"

if [ ! -r "$WRAPPER_SCRIPT" ]; then
  echo "ERROR: Cannot find $WRAPPER_SCRIPT" >&2
  exit 1
fi

find_node() {
  for deveco_home in \
    "${DEVECO_STUDIO_HOME:-}" \
    "${DEVECO_HOME:-}" \
    "/Applications/DevEco-Studio.app/Contents" \
    "/Applications/DevEco Studio.app/Contents" \
    "/opt/DevEco-Studio" \
    "/opt/deveco-studio"; do
    if [ -z "$deveco_home" ]; then
      continue
    fi
    for candidate in \
      "$deveco_home/tools/node/bin/node" \
      "$deveco_home/tools/node/node"; do
      if [ -x "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
      fi
    done
  done

  if [ -n "${NODE_HOME:-}" ]; then
    for candidate in "$NODE_HOME/bin/node" "$NODE_HOME/node"; do
      if [ -x "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
      fi
    done
  fi

  if command -v node >/dev/null 2>&1; then
    command -v node
    return 0
  fi

  return 1
}

if ! NODE_BIN=$(find_node); then
  echo "ERROR: Node.js was not found. Set DEVECO_STUDIO_HOME or NODE_HOME, or add node to PATH." >&2
  exit 1
fi

exec "$NODE_BIN" "$WRAPPER_SCRIPT" "$@"
